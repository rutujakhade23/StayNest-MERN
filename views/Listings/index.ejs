<% layout("/layouts/boilerplate") %>

<h3>All Listings</h3>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

<% for(let listing of allListings) { %>

<div class="col">
<a href="/listings/<%= listing._id %>" class="listing-link">

<div class="card listing-card">
    <img src="<%= listing.image && listing.image.url ? listing.image.url : (listing.image ? listing.image : 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=1200') %>" 
class="card-img-top" alt="listing_image">
    <!-- <img src="<%= listing.image?.url || listing.image || 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=1200' %>"  -->
<!-- class="card-img-top" alt="listing_image"> -->
<!-- <img src="<%= listing.image.url || listing.image %>" class="card-img-top" alt="listing_image"> -->

<div class="card-body">
<p class="card-text">
<b><%= listing.title %></b><br>
<%= listing.price?.toLocaleString("en-IN") || "Price not available" %> /night
</p>
</div>

</div>
</a>
</div>

<% } %>

</div>