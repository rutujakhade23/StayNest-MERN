<% layout("/layouts/boilerplate") %>

<h3>Listing Details :</h3>

<div class="card col-6">
    <img src="<%= listing.image?.url %>" class="card-img-top show-img" alt="listing_image">
    <div class="card-body">
        <p class="card-text"><%= listing.title %></p>
    </div>
</div>

<ul>
    <li><%= listing.title %></li>
    <li><%= listing.description %></li>
    <li>&#8377; <%= listing.price?.toLocaleString("en-IN") || "Price not available" %></li>
    <li><%= listing.location || "Location not available" %></li>
    <li><%= listing.country %></li>
</ul>

<a href="/listings/<%= listing._id %>/edit">Edit this Listing</a>

<form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button>Delete this listing</button>
</form>